{
	"version": "0.2.0",
	"configurations": [
		{
			"name": "TovaIDE: Launch Desktop (all STM32 extensions)",
			"type": "extensionHost",
			"request": "launch",
			"runtimeExecutable": "${workspaceFolder}/scripts/code.bat",
			"windows": { "runtimeExecutable": "${workspaceFolder}/scripts/code.bat" },
			"osx": { "runtimeExecutable": "${workspaceFolder}/scripts/code.sh" },
			"linux": { "runtimeExecutable": "${workspaceFolder}/scripts/code.sh" },
			"args": [
				"--extensionDevelopmentPath=${workspaceFolder}/extensions/stm32-core",
				"--extensionDevelopmentPath=${workspaceFolder}/extensions/stm32-ai",
				"--extensionDevelopmentPath=${workspaceFolder}/extensions/stm32-ux",
				"--extensionDevelopmentPath=${workspaceFolder}/extensions/stm32-collab"
			],
			"outFiles": [
				"${workspaceFolder}/extensions/stm32-core/out/**/*.js",
				"${workspaceFolder}/extensions/stm32-ai/out/**/*.js",
				"${workspaceFolder}/extensions/stm32-ux/out/**/*.js",
				"${workspaceFolder}/extensions/stm32-collab/out/**/*.js"
			],
			"env": {
				"VSCODE_LOG_LEVEL": "debug"
			}
		},
		{
			"name": "Attach to Extension Host (5870)",
			"type": "node",
			"request": "attach",
			"restart": true,
			"port": 5870,
			"timeout": 0,
			"outFiles": [
				"${workspaceFolder}/extensions/*/out/**/*.js"
			]
		},
		{
			"name": "STM32 Smoke Tests (Playwright)",
			"type": "node",
			"request": "launch",
			"program": "${workspaceFolder}/test/smoke/node_modules/mocha/bin/_mocha",
			"cwd": "${workspaceFolder}/test/smoke",
			"args": [
				"--grep",
				"STM32 Extensions",
				"./out/main.js"
			],
			"env": {
				"NODE_ENV": "development"
			},
			"outFiles": [
				"${workspaceFolder}/test/smoke/out/**/*.js"
			]
		}
	],
	"compounds": [
		{
			"name": "TovaIDE Desktop + Attach",
			"configurations": [
				"TovaIDE: Launch Desktop (all STM32 extensions)",
				"Attach to Extension Host (5870)"
			]
		}
	]
}
