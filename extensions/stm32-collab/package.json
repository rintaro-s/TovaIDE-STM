{
  "name": "stm32-collab",
  "displayName": "%displayName%",
  "description": "%description%",
  "version": "0.0.1",
  "publisher": "tova",
  "license": "MIT",
  "engines": {
    "vscode": "^1.70.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./out/extension",
  "activationEvents": [],
  "capabilities": {
    "virtualWorkspaces": false,
    "untrustedWorkspaces": {
      "supported": "limited"
    }
  },
  "contributes": {
    "commands": [
      {
        "command": "stm32collab.openPanel",
        "title": "%command.openPanel.title%",
        "category": "STM32"
      },
      {
        "command": "stm32collab.startSession",
        "title": "%command.startSession.title%",
        "category": "STM32"
      },
      {
        "command": "stm32collab.joinSession",
        "title": "%command.joinSession.title%",
        "category": "STM32"
      },
      {
        "command": "stm32collab.startLanShare",
        "title": "%command.startLanShare.title%",
        "category": "STM32"
      },
      {
        "command": "stm32collab.discoverSessions",
        "title": "%command.discoverSessions.title%",
        "category": "STM32"
      },
      {
        "command": "stm32collab.startRealtimeSync",
        "title": "%command.startRealtimeSync.title%",
        "category": "STM32"
      },
      {
        "command": "stm32collab.stopRealtimeSync",
        "title": "%command.stopRealtimeSync.title%",
        "category": "STM32"
      },
      {
        "command": "stm32collab.stopLanShare",
        "title": "%command.stopLanShare.title%",
        "category": "STM32"
      },
      {
        "command": "stm32collab.startGitDaemon",
        "title": "%command.startGitDaemon.title%",
        "category": "STM32"
      },
      {
        "command": "stm32collab.stopGitDaemon",
        "title": "%command.stopGitDaemon.title%",
        "category": "STM32"
      },
      {
        "command": "stm32collab.shareDebugSnapshot",
        "title": "%command.shareDebugSnapshot.title%",
        "category": "STM32"
      },
      {
        "command": "stm32collab.runQualityAudit",
        "title": "%command.runQualityAudit.title%",
        "category": "STM32"
      },
      {
        "command": "stm32collab.exportProjectZip",
        "title": "%command.exportProjectZip.title%",
        "category": "STM32"
      },
      {
        "command": "stm32collab.startWsSync",
        "title": "%command.startWsSync.title%",
        "category": "STM32"
      },
      {
        "command": "stm32collab.stopWsSync",
        "title": "%command.stopWsSync.title%",
        "category": "STM32"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "stm32-collab",
          "title": "STM32 Collab",
          "icon": "../stm32-core/media/icons/stm32-collab.svg"
        }
      ]
    },
    "views": {
      "stm32-collab": [
        {
          "id": "stm32-collab.panel",
          "type": "webview",
          "name": "Collaboration (Removed)",
          "icon": "../stm32-core/media/icons/stm32-collab.svg"
        }
      ]
    },
    "configuration": {
      "title": "%configuration.title%",
      "properties": {
        "stm32collab.sharePort": {
          "type": "number",
          "default": 8080,
          "minimum": 1024,
          "maximum": 65535,
          "markdownDescription": "%configuration.sharePort.description%"
        },
        "stm32collab.discoveryPort": {
          "type": "number",
          "default": 5353,
          "minimum": 1024,
          "maximum": 65535,
          "markdownDescription": "%configuration.discoveryPort.description%"
        },
        "stm32collab.syncPort": {
          "type": "number",
          "default": 40123,
          "minimum": 1024,
          "maximum": 65535,
          "markdownDescription": "%configuration.syncPort.description%"
        },
        "stm32collab.gitPort": {
          "type": "number",
          "default": 9418,
          "minimum": 1024,
          "maximum": 65535,
          "markdownDescription": "%configuration.gitPort.description%"
        },
        "stm32collab.wsSyncPort": {
          "type": "number",
          "default": 40200,
          "minimum": 1024,
          "maximum": 65535,
          "markdownDescription": "%configuration.wsSyncPort.description%"
        }
      }
    }
  },
  "scripts": {
    "compile": "gulp compile-extension:stm32-collab",
    "watch": "gulp watch-extension:stm32-collab"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/microsoft/vscode.git"
  }
}
