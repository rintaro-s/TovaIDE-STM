{
  "name": "stm32-ai",
  "displayName": "%displayName%",
  "description": "%description%",
  "version": "0.0.1",
  "publisher": "tova",
  "license": "MIT",
  "engines": {
    "vscode": "^1.70.0"
  },
  "enabledApiProposals": [
    "chatParticipantAdditions"
  ],
  "categories": [
    "Other"
  ],
  "main": "./out/extension",
  "activationEvents": [
    "onStartupFinished",
    "onCommand:stm32ai.runSemiAutoFlow",
    "onCommand:stm32ai.runAutoUntilFlash",
    "onCommand:stm32ai.runFullAutoFlow",
    "onCommand:stm32ai.fixBuildError",
    "onCommand:stm32ai.analyzeHardFault",
    "onCommand:stm32ai.startMcpServer",
    "onCommand:stm32ai.stopMcpServer"
  ],
  "capabilities": {
    "virtualWorkspaces": false,
    "untrustedWorkspaces": {
      "supported": "limited"
    }
  },
  "contributes": {
    "commands": [
      {
        "command": "stm32ai.runSemiAutoFlow",
        "title": "%command.runSemiAutoFlow.title%",
        "category": "STM32 AI"
      },
      {
        "command": "stm32ai.runAutoUntilFlash",
        "title": "%command.runAutoUntilFlash.title%",
        "category": "STM32 AI"
      },
      {
        "command": "stm32ai.runFullAutoFlow",
        "title": "%command.runFullAutoFlow.title%",
        "category": "STM32 AI"
      },
      {
        "command": "stm32ai.fixBuildError",
        "title": "%command.fixBuildError.title%",
        "category": "STM32 AI"
      },
      {
        "command": "stm32ai.analyzeHardFault",
        "title": "%command.analyzeHardFault.title%",
        "category": "STM32 AI"
      },
      {
        "command": "stm32ai.startMcpServer",
        "title": "%command.startMcpServer.title%",
        "category": "STM32 AI"
      },
      {
        "command": "stm32ai.stopMcpServer",
        "title": "%command.stopMcpServer.title%",
        "category": "STM32 AI"
      }
    ],
    "chatParticipants": [
      {
        "id": "stm32ai",
        "name": "stm32ai",
        "description": "STM32 assistant for project setup, build, flash and debug workflows.",
        "isDefault": false,
        "commands": [
          {
            "name": "build",
            "description": "Build Debug target"
          },
          {
            "name": "flash",
            "description": "Flash latest build to target"
          },
          {
            "name": "fix",
            "description": "Analyze and fix latest build error"
          },
          {
            "name": "hardfault",
            "description": "Analyze HardFault registers"
          },
          {
            "name": "flow",
            "description": "Run guided STM32 workflow"
          }
        ]
      }
    ],
    "languageModelTools": [
      {
        "name": "stm32Build",
        "displayName": "STM32 Build",
        "toolReferenceName": "stm32Build",
        "canBeReferencedInPrompt": true,
        "modelDescription": "Build STM32 Debug target using stm32-core extension.",
        "userDescription": "Build the STM32 project.",
        "inputSchema": {
          "type": "object",
          "properties": {}
        }
      },
      {
        "name": "stm32Flash",
        "displayName": "STM32 Flash",
        "toolReferenceName": "stm32Flash",
        "canBeReferencedInPrompt": true,
        "modelDescription": "Flash latest STM32 build using stm32-core extension.",
        "userDescription": "Flash the STM32 device.",
        "inputSchema": {
          "type": "object",
          "properties": {}
        }
      },
      {
        "name": "stm32RegenerateCode",
        "displayName": "STM32 Regenerate Code",
        "toolReferenceName": "stm32RegenerateCode",
        "canBeReferencedInPrompt": true,
        "modelDescription": "Regenerate STM32 code from ioc while preserving USER CODE blocks.",
        "userDescription": "Regenerate code from the ioc file.",
        "inputSchema": {
          "type": "object",
          "properties": {}
        }
      },
      {
        "name": "stm32AnalyzeHardFault",
        "displayName": "STM32 HardFault Analysis",
        "toolReferenceName": "stm32AnalyzeHardFault",
        "canBeReferencedInPrompt": true,
        "modelDescription": "Analyze HardFault registers and explain causes.",
        "userDescription": "Analyze a HardFault using register values.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "cfsr": {
              "type": "string",
              "description": "CFSR value in hex, e.g. 0x00008200"
            },
            "hfsr": {
              "type": "string",
              "description": "HFSR value in hex, e.g. 0x40000000"
            }
          },
          "required": [
            "cfsr",
            "hfsr"
          ]
        }
      }
    ],
    "configuration": {
      "title": "%configuration.title%",
      "properties": {
        "stm32ai.autoFlow.includeRegenerate": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "%configuration.includeRegenerate.description%"
        },
        "stm32ai.autoFlow.requireFlashConfirmation": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "%configuration.requireFlashConfirmation.description%"
        },
        "stm32ai.chat.defaultPrompt": {
          "type": "string",
          "default": "Review the current STM32 project and suggest next steps.",
          "markdownDescription": "%configuration.defaultPrompt.description%"
        },
        "stm32ai.mcp.autoStartServer": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "%configuration.mcpAutoStart.description%"
        },
        "stm32ai.mcp.host": {
          "type": "string",
          "default": "127.0.0.1",
          "markdownDescription": "%configuration.mcpHost.description%"
        },
        "stm32ai.mcp.port": {
          "type": "number",
          "default": 3737,
          "minimum": 1024,
          "maximum": 65535,
          "markdownDescription": "%configuration.mcpPort.description%"
        }
      }
    }
  },
  "scripts": {
    "compile": "gulp compile-extension:stm32-ai",
    "watch": "gulp watch-extension:stm32-ai"
  },
  "devDependencies": {
    "@types/node": "22.x"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/microsoft/vscode.git"
  }
}
