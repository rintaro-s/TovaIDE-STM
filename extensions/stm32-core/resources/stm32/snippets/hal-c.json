    ],
    "description": "HAL TIM PWM Start"
  },
  "HAL TIM PWM Set Duty": {
    "prefix": "hal_tim_pwm_duty",
    "body": [
      "__HAL_TIM_SET_COMPARE(&${1:htim2}, ${2:TIM_CHANNEL_1}, ${3:dutyCycle});"
    ],
    "description": "Set PWM duty cycle via __HAL_TIM_SET_COMPARE"
  },
  "HAL TIM Base Start IT": {
    "prefix": "hal_tim_it",
    "body": [
