    ],
    "description": "HAL TIM Base Start with interrupt"
  },
  "HAL TIM Period Elapsed Callback": {
    "prefix": "hal_tim_callback",
    "body": [
      "void HAL_TIM_PeriodElapsedCallback(TIM_HandleTypeDef *htim) {",
      "\tif (htim->Instance == ${1:TIM6}) {",
      "\t\t${2:/* USER CODE */}",
      "\t}",
      "}"
    ],
    "description": "HAL TIM Period Elapsed callback"
  },
  "HAL GPIO EXTI Callback": {
    "prefix": "hal_exti_callback",
    "body": [
      "void HAL_GPIO_EXTI_Callback(uint16_t GPIO_Pin) {",
      "\tif (GPIO_Pin == ${1:GPIO_PIN_0}) {",
      "\t\t${2:/* USER CODE */}",
      "\t}",
      "}"
    ],
    "description": "HAL GPIO EXTI interrupt callback"
  },
  "HAL UART Rx Complete Callback": {
    "prefix": "hal_uart_rx_callback",
    "body": [
      "void HAL_UART_RxCpltCallback(UART_HandleTypeDef *huart) {",
      "\tif (huart->Instance == ${1:USART2}) {",
      "\t\t${2:/* process rxBuf */}",
      "\t\tHAL_UART_Receive_IT(&${3:huart2}, ${4:rxBuf}, ${5:1});",
      "\t}",
      "}"
    ],
    "description": "HAL UART Rx Complete callback (with re-arm)"
  },
  "USER CODE BEGIN": {
    "prefix": "ucb",
    "body": ["/* USER CODE BEGIN ${1:Section} */", "${2}", "/* USER CODE END ${1:Section} */"],
    "description": "STM32CubeMX USER CODE section"
  },
  "HAL GetTick": {
    "prefix": "hal_tick",
    "body": ["uint32_t ${1:now} = HAL_GetTick();"],
    "description": "Get current SysTick millisecond counter"
  },
  "Non-blocking Delay Pattern": {
    "prefix": "hal_nonblocking_delay",
    "body": [
      "static uint32_t ${1:lastTick} = 0;",
      "if (HAL_GetTick() - ${1:lastTick} >= ${2:1000}) {",
      "\t${1:lastTick} = HAL_GetTick();",
      "\t${3:/* periodic action */}",
      "}"
    ],
    "description": "Non-blocking delay using HAL_GetTick"
  },
  "Error Handler": {
    "prefix": "hal_error_handler",
    "body": [
      "void Error_Handler(void) {",
      "\t__disable_irq();",
      "\twhile (1) {",
      "\t\t${1:/* loop forever on error */}",
      "\t}",
      "}"
    ],
    "description": "HAL Error_Handler stub"
  }
