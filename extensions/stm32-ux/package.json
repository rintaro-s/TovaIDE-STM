{
  "name": "stm32-ux",
  "displayName": "%displayName%",
  "description": "%description%",
  "version": "0.0.1",
  "publisher": "tova",
  "license": "MIT",
  "engines": {
    "vscode": "^1.70.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./out/extension",
  "activationEvents": [
    "onStartupFinished",
    "onView:stm32-ux.onboardingView",
    "onCommand:stm32ux.openWorkflowStudio",
    "onCommand:stm32ux.openWelcomeWizard",
    "onCommand:stm32ux.openMcpOperationDesk",
    "onCommand:stm32ux.syncMcuCatalogFromCubeMX",
    "onCommand:stm32ux.startBlinkTutorial",
    "onCommand:stm32ux.openTemplateGallery",
    "onCommand:stm32ux.openBoardConfigurator",
    "onCommand:stm32ux.runEnvironmentCheck",
    "onCommand:stm32ux.explainLatestError",
    "onCommand:stm32ux.openPinVisualizer",
    "onCommand:stm32ux.configureGlobalWallpaper",
    "onCommand:stm32ux.generateMcpConfigJson",
    "onCommand:stm32ux.composeMcpRequestJson"
  ],
  "capabilities": {
    "virtualWorkspaces": false,
    "untrustedWorkspaces": {
      "supported": "limited"
    }
  },
  "contributes": {
    "commands": [
      {
        "command": "stm32ux.openWorkflowStudio",
        "title": "%command.openWorkflowStudio.title%",
        "category": "STM32"
      },
      {
        "command": "stm32ux.openWelcomeWizard",
        "title": "%command.openWelcomeWizard.title%",
        "category": "STM32"
      },
      {
        "command": "stm32ux.openMcpOperationDesk",
        "title": "%command.openMcpOperationDesk.title%",
        "category": "STM32"
      },
      {
        "command": "stm32ux.syncMcuCatalogFromCubeMX",
        "title": "%command.syncMcuCatalogFromCubeMX.title%",
        "category": "STM32"
      },
      {
        "command": "stm32ux.startBlinkTutorial",
        "title": "%command.startBlinkTutorial.title%",
        "category": "STM32"
      },
      {
        "command": "stm32ux.openTemplateGallery",
        "title": "%command.openTemplateGallery.title%",
        "category": "STM32"
      },
      {
        "command": "stm32ux.openBoardConfigurator",
        "title": "%command.openBoardConfigurator.title%",
        "category": "STM32"
      },
      {
        "command": "stm32ux.runEnvironmentCheck",
        "title": "%command.runEnvironmentCheck.title%",
        "category": "STM32"
      },
      {
        "command": "stm32ux.explainLatestError",
        "title": "%command.explainLatestError.title%",
        "category": "STM32"
      },
      {
        "command": "stm32ux.openPinVisualizer",
        "title": "%command.openPinVisualizer.title%",
        "category": "STM32"
      },
      {
        "command": "stm32ux.configureGlobalWallpaper",
        "title": "%command.configureGlobalWallpaper.title%",
        "category": "STM32"
      },
      {
        "command": "stm32ux.generateMcpConfigJson",
        "title": "%command.generateMcpConfigJson.title%",
        "category": "STM32"
      },
      {
        "command": "stm32ux.composeMcpRequestJson",
        "title": "%command.composeMcpRequestJson.title%",
        "category": "STM32"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "stm32-ux",
          "title": "STM32 Start",
          "icon": "../stm32-core/media/icons/stm32-ux.svg"
        }
      ]
    },
    "views": {
      "stm32-ux": [
        {
          "id": "stm32-ux.onboardingView",
          "type": "webview",
          "name": "オンボーディング",
          "icon": "../stm32-core/media/icons/stm32-ux.svg"
        }
      ]
    },
    "configuration": {
      "title": "%configuration.title%",
      "properties": {
        "stm32ux.autoOpenWelcome": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "%configuration.autoOpenWelcome.description%"
        },
        "stm32ux.mcp.autoStart": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "%configuration.mcp.autoStart.description%"
        },
        "stm32ux.mcp.transport": {
          "type": "string",
          "default": "stdio",
          "enum": [
            "stdio",
            "http"
          ],
          "markdownDescription": "%configuration.mcp.transport.description%"
        },
        "stm32ux.mcp.host": {
          "type": "string",
          "default": "127.0.0.1",
          "markdownDescription": "%configuration.mcp.host.description%"
        },
        "stm32ux.mcp.port": {
          "type": "number",
          "default": 61337,
          "minimum": 1,
          "maximum": 65535,
          "markdownDescription": "%configuration.mcp.port.description%"
        },
        "stm32ux.mcp.requestTimeoutMs": {
          "type": "number",
          "default": 20000,
          "minimum": 1000,
          "maximum": 180000,
          "markdownDescription": "%configuration.mcp.requestTimeoutMs.description%"
        }
      }
    }
  },
  "scripts": {
    "compile": "gulp compile-extension:stm32-ux",
    "watch": "gulp watch-extension:stm32-ux"
  },
  "devDependencies": {
    "@types/node": "22.x"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/microsoft/vscode.git"
  }
}
